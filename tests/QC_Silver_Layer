/*
===============================================================================
DATA QUALITY CHECKS – SILVER LAYER (PostgreSQL)
===============================================================================

🎯 Purpose:
    This script validates data quality in the Silver Layer by checking:
    - Primary key uniqueness
    - Null values
    - String cleanliness (trimming spaces)
    - Data standardization
    - Date validity and logical consistency
    - Business rule validation

📌 When to Run:
    - After loading Silver Layer
    - Before building Gold Layer

⚠️ Expected Output:
    - All queries should return ZERO rows (except DISTINCT checks)
    - Any output indicates data quality issues

===============================================================================
*/


-- =============================================================================
-- 1. CHECK: silver.crm_cust_info
-- =============================================================================

-- Check for NULLs or duplicate primary keys
SELECT 
    cst_id,
    COUNT(*) 
FROM silver.crm_cust_info
GROUP BY cst_id
HAVING COUNT(*) > 1 OR cst_id IS NULL;

-- Check for unwanted spaces
SELECT 
    cst_key 
FROM silver.crm_cust_info
WHERE cst_key <> TRIM(cst_key);

-- Check data standardization
SELECT DISTINCT 
    cst_marital_status 
FROM silver.crm_cust_info;



-- =============================================================================
-- 2. CHECK: silver.crm_prd_info
-- =============================================================================

-- Check for NULLs or duplicate primary keys
SELECT 
    prd_id,
    COUNT(*) 
FROM silver.crm_prd_info
GROUP BY prd_id
HAVING COUNT(*) > 1 OR prd_id IS NULL;

-- Check for unwanted spaces
SELECT 
    prd_nm 
FROM silver.crm_prd_info
WHERE prd_nm <> TRIM(prd_nm);

-- Check for NULL or negative cost
SELECT 
    prd_cost 
FROM silver.crm_prd_info
WHERE prd_cost < 0 OR prd_cost IS NULL;

-- Check standardization
SELECT DISTINCT 
    prd_line 
FROM silver.crm_prd_info;

-- Check invalid date range
SELECT 
    * 
FROM silver.crm_prd_info
WHERE prd_end_dt < prd_start_dt;



-- =============================================================================
-- 3. CHECK: silver.crm_sale_info
-- =============================================================================

-- Check invalid raw date format (from bronze)
SELECT 
    sls_due_dt
FROM bronze.crm_sales_details
WHERE sls_due_dt::TEXT !~ '^[0-9]{8}$'
   OR sls_due_dt::TEXT::BIGINT > 20500101
   OR sls_due_dt::TEXT::BIGINT < 19000101;

-- Check logical date order
SELECT 
    * 
FROM silver.crm_sale_info
WHERE sls_order_dt > sls_ship_dt 
   OR sls_order_dt > sls_due_dt;

-- Check business rule: sales = quantity * price
SELECT DISTINCT 
    sls_sales,
    sls_quantity,
    sls_price 
FROM silver.crm_sale_info
WHERE sls_sales <> sls_quantity * sls_price
   OR sls_sales IS NULL 
   OR sls_quantity IS NULL 
   OR sls_price IS NULL
   OR sls_sales <= 0 
   OR sls_quantity <= 0 
   OR sls_price <= 0
ORDER BY sls_sales, sls_quantity, sls_price;



-- =============================================================================
-- 4. CHECK: silver.erp_cust
-- =============================================================================

-- Check invalid birthdates
SELECT DISTINCT 
    bdate 
FROM silver.erp_cust
WHERE bdate < DATE '1924-01-01' 
   OR bdate > CURRENT_DATE;

-- Check gender standardization
SELECT DISTINCT 
    gen 
FROM silver.erp_cust;



-- =============================================================================
-- 5. CHECK: silver.erp_loc
-- =============================================================================

-- Check country standardization
SELECT DISTINCT 
    cntry 
FROM silver.erp_loc
ORDER BY cntry;



-- =============================================================================
-- 6. CHECK: silver.erp_cat
-- =============================================================================

-- Check for unwanted spaces
SELECT 
    * 
FROM silver.erp_cat
WHERE cat <> TRIM(cat) 
   OR subcat <> TRIM(subcat) 
   OR maintenance <> TRIM(maintenance);

-- Check maintenance standardization
SELECT DISTINCT 
    maintenance 
FROM silver.erp_cat;



